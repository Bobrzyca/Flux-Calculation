# Copy to .env and adjust. .env is git-ignored.

# Base URL of the FastAPI backend. Must match the backend's CORS_ORIGINS.
VITE_API_BASE_URL=http://localhost:8000/api

# Minimum log level printed by the app logger:
#   debug | info | warn | error | silent
# Leave unset to use the default: debug in dev, warn in production builds.
VITE_LOG_LEVEL=

# --- Monitoring (Sentry, browser) ------------------------------------------
# Optional: with VITE_SENTRY_DSN blank, monitoring is off. The DSN is public
# (it ships in the bundle). All are inlined at build time.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0
