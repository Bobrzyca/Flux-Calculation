# Flux Calculation — project environment.
# Copy to .env and fill in as needed:  cp .env.example .env
# .env is git-ignored and must never be committed.
#
# Consumed by docker-compose.yml: the backend reads these via env_file; the
# frontend reads VITE_API_BASE_URL as a build arg; Traefik reads DOMAIN /
# ACME_EMAIL for routing + Let's Encrypt.

# --- Traefik / HTTPS -------------------------------------------------------

# Public hostname the app is served at. Traefik routes Host(DOMAIN) to the
# frontend and Host(DOMAIN)+/api to the backend, and requests a Let's Encrypt
# certificate for it.
DOMAIN=flux-calculation.aibr.cz

# Contact address Let's Encrypt uses for expiry notices (ACME registration).
ACME_EMAIL=zuzakulis@gmail.com

# --- Backend (FastAPI) -----------------------------------------------------

# Display name of the API (shown by /api/health).
APP_NAME=Flux Calculation API

# Where uploaded files + the SQLite DB live INSIDE the container. This path is
# backed by the `backend-data` Docker volume, so data survives rebuilds.
DATA_DIR=/app/data

# SQLite connection string (four slashes = absolute path in the container).
DATABASE_URL=sqlite:////app/data/flux.db

# Allowed CORS origins as a JSON list. In production nginx proxies /api so the
# app is same-origin and this is not strictly needed; set it to the public URL
# if the frontend is ever served from a different origin.
CORS_ORIGINS=["https://flux-calculation.aibr.cz"]

# LLM field-notes/pressure parser key — seminar 6. Leave blank for now.
LLM_API_KEY=

# --- Monitoring (Sentry) ---------------------------------------------------
# All optional: with the DSNs blank the app builds and runs fully unmonitored.
# Create a free project at sentry.io, then paste the DSNs below.

# Backend DSN (server-side). Not printed by logs; kept here with other config.
SENTRY_DSN=
# Browser DSN (public — it is inlined into the JS bundle). Often the same
# project's "frontend" DSN. Safe to expose.
VITE_SENTRY_DSN=
# Environment tag on every event.
SENTRY_ENVIRONMENT=production
VITE_SENTRY_ENVIRONMENT=production
# Performance trace sample rate, 0..1 (0 = off; keep low on the free tier).
SENTRY_TRACES_SAMPLE_RATE=0
VITE_SENTRY_TRACES_SAMPLE_RATE=0
# SENTRY_RELEASE is NOT set here — supply the git SHA at deploy time instead:
#   export SENTRY_RELEASE=$(git rev-parse HEAD)
# docker compose reads it for both apps (backend env + frontend build arg).

# Source-map upload (readable frontend stack traces). SECRET auth token — used
# ONLY during `docker compose build`. Leave blank to skip map upload.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Frontend (nginx / build) ----------------------------------------------

# Base URL the browser uses for API calls, inlined into the bundle at build
# time. Keep "/api" (relative) so Traefik routes it to the backend container.
VITE_API_BASE_URL=/api
