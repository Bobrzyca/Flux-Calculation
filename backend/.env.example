# Copy to .env and adjust. Never commit .env (it is git-ignored).

APP_NAME=Flux Calculation API

# Where uploaded files and the SQLite database live.
DATA_DIR=./data
DATABASE_URL=sqlite:///./data/flux.db

# Comma-separated / JSON list of allowed CORS origins (the Vite dev server).
CORS_ORIGINS=["http://localhost:5173"]

# LLM field-notes/pressure parser — seminar 6. Leave blank for now.
LLM_API_KEY=

# --- Monitoring (Sentry) --------------------------------------------------
# Optional: with SENTRY_DSN blank the backend runs fully unmonitored.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Release id — leave blank in dev (falls back to `git rev-parse HEAD`); in
# production set it from the git SHA at deploy time.
SENTRY_RELEASE=
# Performance trace sample rate, 0..1 (0 = off).
SENTRY_TRACES_SAMPLE_RATE=0
