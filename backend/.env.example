# Copy to .env and adjust. Never commit .env (it is git-ignored).

APP_NAME=Flux Calculation API

# Where uploaded files and the SQLite database live.
DATA_DIR=./data
DATABASE_URL=sqlite:///./data/flux.db

# Comma-separated / JSON list of allowed CORS origins (the Vite dev server).
CORS_ORIGINS=["http://localhost:5173"]

# Upper CO₂ plausibility bound (ppm): readings at/above this are dropped as
# sensor artefacts. Default 5000; lower to 1500 for the strict R method.
MAX_VALID_CO2_PPM=5000

# Optional upper CH₄ plausibility bound (ppb). Blank = NO cap (the default):
# genuine off-scale rises are kept and only negative CH₄ is dropped. Set a value
# (e.g. 100000) to re-enable the old laser mode-hop guard for a noisy campaign.
MAX_VALID_CH4_PPB=

# LLM field-notes/pressure parser — seminar 6. Leave blank for now.
LLM_API_KEY=

# --- Monitoring (Sentry) --------------------------------------------------
# Optional: with SENTRY_DSN blank the backend runs fully unmonitored.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Release id — leave blank in dev (falls back to `git rev-parse HEAD`); in
# production set it from the git SHA at deploy time.
SENTRY_RELEASE=
# Performance trace sample rate, 0..1 (0 = off).
SENTRY_TRACES_SAMPLE_RATE=0
