# Copy to .env and adjust. Never commit .env (it is git-ignored).

APP_NAME=Flux Calculation API

# Where uploaded files and the SQLite database live.
DATA_DIR=./data
DATABASE_URL=sqlite:///./data/flux.db

# Comma-separated / JSON list of allowed CORS origins (the Vite dev server).
CORS_ORIGINS=["http://localhost:5173"]

# LLM field-notes/pressure parser — seminar 6. Leave blank for now.
LLM_API_KEY=
